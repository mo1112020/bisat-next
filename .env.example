# ── AI ───────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────────────────────────────
# The canonical URL where this app is hosted (no trailing slash).
# Used for SSR meta injection, canonical links, sitemaps, and schema markup.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
NEXT_PUBLIC_SITE_URL="https://bisat-store.com"

# ── Facebook / Meta Pixel ─────────────────────────────────────────────────────
# Found in: Meta Business Manager → Events Manager → Your Pixel → Settings
VITE_FB_PIXEL_ID=""

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Format: G-XXXXXXXXXX
# Found in: Google Analytics → Admin → Data Streams → Web stream details
VITE_GA_MEASUREMENT_ID=""

# ── TikTok Pixel ─────────────────────────────────────────────────────────────
# Found in: TikTok Ads Manager → Assets → Events → Web Events → Pixel
VITE_TIKTOK_PIXEL_ID=""

# ── Hotjar ────────────────────────────────────────────────────────────────────
# Found in: Hotjar → Settings → Sites & Organizations → Tracking Code (numeric ID)
VITE_HOTJAR_SITE_ID=""

# ── Microsoft Clarity ────────────────────────────────────────────────────────
# Found in: clarity.microsoft.com → Your Project → Settings (alphanumeric string)
VITE_CLARITY_PROJECT_ID=""
